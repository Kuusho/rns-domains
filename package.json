{
  "name": "rns-domains",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "private": true,
  "scripts": {
    "compile": "hardhat compile",
    "format": "prettier --write \"contracts/**/*.sol\" \"{deploy,scripts,test}/**/*.ts\" \"frontend/generative/**/*.ts\"",
    "format:check": "prettier --check \"contracts/**/*.sol\" \"{deploy,scripts,test}/**/*.ts\" \"frontend/generative/**/*.ts\"",
    "test": "bun run compile && NODE_OPTIONS=\"--disable-warning=ExperimentalWarning\" vitest run",
    "deploy:local": "hardhat deploy --network localhost --skip-prompts",
    "deploy:testnet": "hardhat deploy --network riseTestnet --skip-prompts",
    "verify:testnet": "node --experimental-strip-types --no-warnings scripts/verify-testnet-deploy.ts",
    "verify:testnet:live": "node --experimental-strip-types --no-warnings scripts/verify-testnet-deploy.ts --live",
    "verify:testnet:hh": "hardhat run scripts/verify-testnet-deploy.ts --network riseTestnet --no-compile",
    "deploy:rise-testnet": "hardhat deploy --network riseTestnet --skip-prompts",
    "verify:registration:testnet": "node --experimental-strip-types --no-warnings scripts/verify-registration-testnet.ts",
    "verify:registration:testnet:live": "node --experimental-strip-types --no-warnings scripts/verify-registration-testnet.ts --live"
  },
  "devDependencies": {
    "@ensdomains/hardhat-chai-matchers-viem": "^0.1.14",
    "@nomicfoundation/hardhat-keystore": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "@nomicfoundation/hardhat-viem": "^3.0.0",
    "@rocketh/deploy": "0.14.0",
    "@rocketh/read-execute": "0.14.0",
    "@rocketh/viem": "0.14.0",
    "@types/node": "^18.0.0",
    "abitype": "^1.0.8",
    "chai": "^5.1.1",
    "dotenv": "^16.4.5",
    "hardhat": "3.1.4",
    "hardhat-deploy": "2.0.0-next.35",
    "prettier": "^2.6.2",
    "prettier-plugin-solidity": "^1.0.0-beta.24",
    "rocketh": "0.14.5",
    "typescript": "5.9.2",
    "viem": "2.33.3",
    "vitest": "^3.2.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "4.9.3",
    "@openzeppelin/contracts-v5": "npm:@openzeppelin/contracts@5.1.0"
  },
  "resolutions": {
    "hardhat": "3.1.4"
  },
  "volta": {
    "node": "24.6.0"
  }
}
